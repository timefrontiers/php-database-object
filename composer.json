{
  "name": "timefrontiers/php-database-object",
  "description": "SQL Database Object trait for Active Record pattern",
  "type": "library",
  "license": "MIT",
  "version": "1.0.1",
  "keywords": ["php", "database", "orm", "active-record", "sql"],
  "authors": [
    {
      "name": "TimeFrontiers",
      "email": "dev@timefrontiers.com",
      "homepage": "https://timefrontiers.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "timefrontiers/php-sql-database": "^1.0",
    "timefrontiers/php-has-errors": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "suggest": {
    "timefrontiers/php-instance-error": "For extracting and filtering errors by user rank"
  },
  "autoload": {
    "psr-4": {
      "TimeFrontiers\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TimeFrontiers\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  }
}
